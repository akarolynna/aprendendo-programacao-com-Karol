Algoritmo "classificador_20"

Var
   numero: inteiro


Inicio
   escreval("Informe um número: ")
   leia(numero)

   se (numero >20) entao
      escreva(numero, " maior que 20")
   senao
      se (numero <20) entao
         escreva(numero, " menor que 20")
      senao
         escreva(numero, " igual a 20")
      fimse
   fimse


Fimalgoritmo